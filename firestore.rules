rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only the signed-in user can read/write their own documents
    // This works if your docs have a userId field matching the writer's UID,
    // OR if you just want any authenticated user to access any document.

    match /careTeam/{doc} {
      allow read, write: if request.auth != null;
    }
    match /appointments/{doc} {
      allow read, write: if request.auth != null;
    }
    match /medications/{doc} {
      allow read, write: if request.auth != null;
    }
    match /conditions/{doc} {
      allow read, write: if request.auth != null;
    }
    match /history/{doc} {
      allow read, write: if request.auth != null;
    }
    match /trends/{doc} {
      allow read, write: if request.auth != null;
    }
    match /days/{doc} {
      allow read, write: if request.auth != null;
    }
    match /supplements/{doc} {
      allow read, write: if request.auth != null;
    }
    match /medicationHistory/{doc} {
      allow read, write: if request.auth != null;
    }    
    match /automaticThoughtRecords/{recordId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
}    
  }
}

